---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Case Studies | Wet Dog Drones"
  description="Real projects. Real dollars saved. See how Wet Dog Drones documentation protects Colorado construction projects from disputes and change orders.">

  <section class="bg-slate-900 text-white py-20">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Real Projects. Real Dollars Saved.</h1>
      <p class="text-xl text-slate-300">Documentation that pays for itself — sometimes 10x over.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-4 max-w-6xl">
      
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Case Study 1 -->
        <a href="/case-studies/severance-library" class="bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-xl transition block">
          <div class="bg-gradient-to-br from-blue-600 to-blue-800 h-56 flex items-center justify-center">
            <span class="text-7xl">🏛️</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-1 rounded">$40,000 SAVED</span>
            </div>
            <h2 class="text-2xl font-bold mb-3">Severance Library</h2>
            <p class="text-slate-600 mb-4">Pre-construction baseline documentation showed existing road damage before construction began. Split an $80K change order.</p>
            <div class="flex items-center text-blue-600 font-semibold">
              Read the Story →
            </div>
          </div>
        </a>

        <!-- Case Study 2 -->
        <a href="/case-studies/clear-creek-schools" class="bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-xl transition block">
          <div class="bg-gradient-to-br from-amber-600 to-amber-800 h-56 flex items-center justify-center">
            <span class="text-7xl">🏫</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-1 rounded">$400,000 SAVED</span>
            </div>
            <h2 class="text-2xl font-bold mb-3">Clear Creek Schools</h2>
            <p class="text-slate-600 mb-4">Interior documentation proved building was empty when copper went missing. GC ate the $400K change order.</p>
            <div class="flex items-center text-blue-600 font-semibold">
              Read the Story →
            </div>
          </div>
        </a>

        <!-- Case Study 3 -->
        <a href="/case-studies/severmore-project" class="bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-xl transition block">
          <div class="bg-gradient-to-br from-slate-600 to-slate-800 h-56 flex items-center justify-center">
            <span class="text-7xl">🏗️</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-1 rounded">16 MONTHS</span>
            </div>
            <h2 class="text-2xl font-bold mb-3">The $58 Million Project</h2>
            <p class="text-slate-600 mb-4">14 months of progress compressed into an 85-second time-lapse. Bi-weekly flights from groundbreaking to closeout.</p>
            <div class="flex items-center text-blue-600 font-semibold">
              See the Timeline →
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-slate-900 text-white">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-12">The Bottom Line</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <div class="text-5xl font-bold text-green-400 mb-2">$440K+</div>
          <div class="text-slate-300">Total client savings documented</div>
        </div>
        <div>
          <div class="text-5xl font-bold text-blue-400 mb-2">3</div>
          <div class="text-slate-300">Major disputes won with data</div>
        </div>
        <div>
          <div class="text-5xl font-bold text-amber-400 mb-2">∞</div>
          <div class="text-slate-300">Peace of mind (priceless)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <h2 class="text-3xl font-bold mb-6">Your Project Could Be Next</h2>
      <p class="text-lg text-slate-600 mb-8">
        Every construction project over $5M needs documentation. The question is whether you'll have it before the dispute or after.
      </p>
      <a href="/contact" class="bg-blue-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-blue-700 transition text-lg inline-block">
        Get a Quote for Your Project
      </a>
    </div>
  </section>
</Layout>
