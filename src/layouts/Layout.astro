--- 
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Construction drone services in Colorado. Progress monitoring, pre-construction documentation, and volumetric analysis that save projects money." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-21F0KTCMZE"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-21F0KTCMZE');
    </script>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Local Business Schema -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Wet Dog Drones",
        "image": "https://wetdogdrones.net/images/hhes-hero.jpg",
        "description": "Expert construction drone services in Colorado. Progress monitoring, volumetric analysis, and 3D mapping for $100M+ projects.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Denver",
          "addressRegion": "CO",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "39.7392", 
          "longitude": "-104.9902"
        },
        "url": "https://wetdogdrones.net",
        "telephone": "",
        "email": "info@wetdogdrones.com",
        "serviceArea": {
          "@type": "GeoCircle",
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": "39.7392",
            "longitude": "-104.9902"
          },
          "radius": "200000"
        }
      }
    </script>
    
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" is:inline></script>
  </head>
  <body class="bg-white text-slate-900">
    <header class="bg-slate-900 text-white">
      <nav class="container mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold flex items-center gap-3">
          <img src="/wetdog-logo.png" alt="Wet Dog Drones Logo" class="h-8 w-auto object-contain max-w-[120px]" />
          <span>Wet Dog Drones</span>
        </a>
        <!-- Hamburger button (mobile only) -->
        <button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Desktop nav -->
        <div class="hidden md:flex gap-6 items-center">
          <a href="/services" class="hover:text-blue-400 transition">Services</a>
          
          <!-- Projects Dropdown -->
          <div class="relative group">
            <button class="hover:text-blue-400 transition flex items-center gap-1">
              Projects
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" id="mobile-projects-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute left-0 top-full hidden group-hover:block w-48 bg-slate-800 text-white shadow-lg rounded py-2 z-50">
              <a href="https://wetdogdrones.net/rhsp" class="block px-4 py-2 hover:bg-slate-700 transition">Ruby Hill Sport (RHSP)</a>
              <a href="https://wetdogdrones.net/hhes" class="block px-4 py-2 hover:bg-slate-700 transition">Holly Hills (HHES)</a>
              <a href="https://wetdogdrones.net/dcsdes50" class="block px-4 py-2 hover:bg-slate-700 transition">Douglas County (ES50)</a>
            </div>
          </div>

          <a href="/case-studies" class="hover:text-blue-400 transition">Case Studies</a>
          <a href="/blog" class="hover:text-blue-400 transition">Blog</a>
          <a href="/about" class="hover:text-blue-400 transition">About</a>
          <a href="/contact" class="bg-blue-600 px-4 py-2 rounded hover:bg-blue-700 transition">Contact</a>
        </div>
      </nav>

      <!-- Mobile nav dropdown -->
      <div id="mobile-menu" class="hidden md:hidden bg-slate-800 px-4 pb-4">
        <a href="/services" class="block py-2 hover:text-blue-400 transition">Services</a>
        <div>
          <button id="mobile-projects-btn" class="w-full text-left py-2 hover:text-blue-400 transition flex justify-between items-center">
            Projects
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" id="mobile-projects-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="mobile-projects-sub" class="hidden pl-4">
            <a href="https://wetdogdrones.net/rhsp" class="block py-2 hover:text-blue-400 transition">Ruby Hill Sport (RHSP)</a>
            <a href="https://wetdogdrones.net/hhes" class="block py-2 hover:text-blue-400 transition">Holly Hills (HHES)</a>
            <a href="https://wetdogdrones.net/dcsdes50" class="block py-2 hover:text-blue-400 transition">Douglas County (ES50)</a>
          </div>
        </div>
        <a href="/case-studies" class="block py-2 hover:text-blue-400 transition">Case Studies</a>
        <a href="/blog" class="block py-2 hover:text-blue-400 transition">Blog</a>
        <a href="/about" class="block py-2 hover:text-blue-400 transition">About</a>
        <a href="/contact" class="block mt-2 text-center bg-blue-600 py-2 rounded hover:bg-blue-700 transition">Contact</a>
      </div>
    </header>

    <main>
      <slot />
    </main>
    
    <footer class="bg-slate-900 text-white mt-20">
      <div class="container mx-auto px-4 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-bold text-lg mb-4">Wet Dog Drones</h3>
            <p class="text-slate-400">Construction drone services in Colorado. Part 107 certified. Decision-grade data in 24–48 hours.</p>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Services</h3>
            <ul class="text-slate-400 space-y-2">
              <li><a href="/services" class="hover:text-white transition">Progress Monitoring</a></li>
              <li><a href="/services" class="hover:text-white transition">Pre-Construction Docs</a></li>
              <li><a href="/services" class="hover:text-white transition">Volumetric Analysis</a></li>
              <li><a href="/services" class="hover:text-white transition">3D Modeling</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Contact</h3>
            <p class="text-slate-400">Colorado, USA</p>
            <a href="mailto:info@wetdogdrones.com" class="text-blue-400 hover:text-blue-300 transition">
              info@wetdogdrones.com
            </a>
          </div>
        </div>
        <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-500 text-sm">
          © 2026 Wet Dog Drones. All rights reserved.
        </div>
      </div>
    </footer>
    <script is:inline>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const projectsBtn = document.getElementById('mobile-projects-btn');
      const projectsSub = document.getElementById('mobile-projects-sub');
      const projectsArrow = document.getElementById('mobile-projects-arrow');

      menuBtn?.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      projectsBtn?.addEventListener('click', () => {
        projectsSub.classList.toggle('hidden');
        projectsArrow.classList.toggle('rotate-180');
      });
    </script>
  </body>
</html>